namespace OP;

//	...
$args = OP()->Unit()->Router()->Args();
$cate = $args[0] ?? null;
$meta = $args[1] ?? null;
$name = $args[2] ?? null;
$file = $args[3] ?? null;

?>
<section>
	<div id="develop">
		<div class="flex">
			<div>
			<?php
			//	...
			switch( $cate ){
				//	...
				case 'phpinfo':
					include('phpinfo.php');
					break;

				/*
				case 'reference':
					$ext = 'md';
					break;
				*/

				case 'admin':
				case 'testcase':
				case 'sandbox':
					$ext = 'php';
					break;

				case 'tutorial':
				case 'reference':
					OP()->Template('tutorial.phtml', ['name'=>$cate]);
					break;

				//	...
				default:
					D($cate);
			}

			//	...
			if( $meta === 'app' ){
				$path = "asset:/{$cate}/{$name}.{$ext}";
			}else
			if( $meta === 'core' ){
				$path = "{$meta}:/{$cate}/{$name}.{$ext}";
			}else if( $file ?? null ){
				$path = "asset:/{$meta}/{$name}/{$cate}/{$file}.{$ext}";
			}else{
				$path = false;
			}

			//	...
			if( $path ){
				//	...
				if( $ext === 'md' ){
					$path = OP()->Path($path);
					$text = file_get_contents($path);
					OP()->Html($text, 'div.markdown');
				}else{
					OP()->Template($path);
				}
			}

			?>
			</div>
		</div>
	</div>
</section>

<!-- Markdown -->
<?php
//	...
OP()->Unit()->WebPack()->Auto('./webpack/markdown.*');
//	...
$src = '//cdn.jsdelivr.net/npm/marked/marked.min.js';
?>
<script src="<?= $src ?>"></script>

<!-- Syntax Highlight -->
<?php
$src = '//cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/highlight.min.js';
?>
<script src="<?= $src ?>"></script>
